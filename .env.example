# Environment variables for Playwright E2E tests

# Base URL for testing
# 根據環境修改此值
# Development: http://localhost:3000
# Staging: https://staging.gigabyte.com/
# Production: https://www.gigabyte.com/
BASE_URL=https://www.gigabyte.com/

# 環境設定 (development, staging, production)
ENVIRONMENT=production

# (可選) 如果需要登入測試，請設定以下變數
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=your-password

# (可選) API 相關設定
# API_BASE_URL=https://api.gigabyte.com/
# API_KEY=your-api-key

# (可選) 語言/地區設定
# LANGUAGE=en
# LOCALE=en-US
